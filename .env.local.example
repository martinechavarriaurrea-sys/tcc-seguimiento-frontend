# Backend FastAPI URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Activar modo mock (sin backend real)
# Poner en "true" para desarrollar sin backend
NEXT_PUBLIC_MOCK_MODE=false

# Nombre del sistema (aparece en UI)
NEXT_PUBLIC_APP_NAME="TCC Seguimiento"

# Duración del token en horas (para info en UI)
NEXT_PUBLIC_TOKEN_EXPIRY_HOURS=24
